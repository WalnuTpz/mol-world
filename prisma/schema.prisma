generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum MemeType {
  STATIC
  ANIMATED
}

enum MemeStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

model Meme {
  id         String     @id @default(cuid())
  title      String?
  type       MemeType
  mediaUrl   String
  thumbUrl   String
  downloads  Int        @default(0)
  isFeatured Boolean    @default(false)
  status     MemeStatus @default(PUBLISHED)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tags       MemeTag[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  memes MemeTag[]
}

model MemeTag {
  memeId String
  tagId  String
  meme   Meme @relation(fields: [memeId], references: [id])
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([memeId, tagId])
}
