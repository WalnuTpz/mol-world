generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MemeType {
  STATIC
  ANIMATED
}

enum MemeStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

model Meme {
  id         String     @id @default(cuid())
  numId      Int?       @unique
  title      String?
  type       MemeType
  mediaUrl   String
  thumbUrl   String
  copies     Int        @default(0)
  downloads  Int        @default(0)
  isFeatured Boolean    @default(false)
  status     MemeStatus @default(PUBLISHED)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tags       MemeTag[]
  dailyPools DailyPoolItem[]
  dailyStats MemeDailyStat[]
}

model Tag {
  id    String    @id @default(cuid())
  numId Int?      @unique
  name  String    @unique
  memes MemeTag[]
}

model MemeTag {
  memeId String
  tagId  String
  meme   Meme @relation(fields: [memeId], references: [id])
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([memeId, tagId])
}

model MemeDailyStat {
  day       String
  memeId    String
  copies    Int    @default(0)
  downloads Int    @default(0)
  meme      Meme   @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@id([day, memeId])
  @@index([day])
  @@index([memeId])
}

model DailyPool {
  id         String          @id @default(cuid())
  day        String
  groupIndex Int
  items      DailyPoolItem[]

  @@unique([day, groupIndex])
}

model DailyPoolItem {
  id     String    @id @default(cuid())
  poolId String
  memeId String

  pool DailyPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  meme Meme      @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@unique([poolId, memeId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  status     String
  targetType String?
  targetId   String?
  message    String?
  data       Json?
  actorIp    String?
  actorUa    String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([status])
  @@index([createdAt])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
