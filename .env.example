# Copy this file to `.env` for local development:
#   cp .env.example .env

# Prisma / SQLite
# Local default database file (created automatically after migrate/seed).
DATABASE_URL="file:./prisma/dev.db"

# Admin login fallback credential (used when DB admin credential is not initialized yet).
# Change these before production deployment.
REVIEW_USER="admin"
REVIEW_PASS="change-this-password"

# Note:
# - `NODE_ENV` is usually set by Next.js (`pnpm dev` / `pnpm start`), no need to set manually.
# - Do NOT commit real `.env` / `.env.production` files.
